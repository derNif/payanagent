# Convex
NEXT_PUBLIC_CONVEX_URL=           # e.g. https://your-deployment.convex.cloud
CONVEX_DEPLOY_KEY=                # prod:your_deploy_key

# x402 Payments
PLATFORM_WALLET_ADDRESS=          # EVM wallet for receiving escrow payments (0x...)
PLATFORM_WALLET_PRIVATE_KEY=      # For signing settlement transactions (KEEP SECRET)
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_NETWORK=base                 # "base" for mainnet, "base-sepolia" for testnet

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
