# Convex
CONVEX_DEPLOYMENT=dev:your-deployment-name
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# x402 Payment Configuration
# Network: "base-sepolia" (testnet) or "base" (mainnet)
X402_NETWORK=base-sepolia

# Platform wallet — receives x402 payments and releases escrow
PLATFORM_WALLET_ADDRESS=0xYourWalletAddress
PLATFORM_WALLET_PRIVATE_KEY=0xYourPrivateKey

# Optional: Override the default x402 facilitator URL
# Testnet default: https://x402.org/facilitator
# Mainnet default: https://facilitator.xpay.sh
# X402_FACILITATOR_URL=

# Admin dashboard — access at /admin?key=YOUR_SECRET
# Server-side only (never exposed to client)
ADMIN_KEY=change-me-to-a-random-string

# Upstash Redis — distributed rate limiting (optional, but required in production)
# Get these from the Upstash console: https://console.upstash.com
# Without these, rate limiting falls back to in-memory (not shared across serverless instances).
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Optional platform routing fee, in basis points (100 = 1%). Default 0 = OFF
# (every fee code path is a no-op). Non-custodial: a second buyer-signed leg.
# PAYANAGENT_FEE_BPS=0

# Optional public contact (a role address, never personal) — lets x402 directories
# verify origin ownership. Omitted from manifests if unset.
# PUBLIC_CONTACT_EMAIL=hello@yourdomain.com

# Shared secret protecting internal platform service endpoints from direct calls.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PLATFORM_INTERNAL_KEY=change-me-to-a-random-string

# REQUIRED: HMAC signing key for receipts. MUST be set and MUST be distinct from
# the wallet private key (receipts are the trust layer). Set in the Convex env.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PLATFORM_RECEIPT_SECRET=change-me-to-a-random-string

# PayanAgent Labs upstream provider (server-side only). Powers the first-party
# Labs offers; the vendor identity lives only here, never in the repo.
LABS_UPSTREAM_BASE_URL=https://your-upstream-provider
LABS_UPSTREAM_KEY=your-upstream-api-key
LABS_UPSTREAM_ANSWER_MODEL=your-answer-model
